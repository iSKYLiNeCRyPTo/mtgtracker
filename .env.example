# MTGTracker Environment Variables
# Copy this file to .env and fill in your values
# For Cloudflare Pages: add these as environment variables in the dashboard

# ── Firebase (required for sync & embedding index) ──────────────────────────
# Create a project at https://console.firebase.google.com
# Enable: Authentication (Google sign-in), Firestore, Storage
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Optional: Cloudflare Worker proxy ───────────────────────────────────────
# If you deploy a CF Worker to proxy Firebase Storage (avoids CORS on large
# binary files like the embedding index), set its URL here.
# Without this, the app falls back to direct Firebase Storage requests.
VITE_CF_WORKER=https://your-worker.workers.dev

# ── Optional: PIN lock ───────────────────────────────────────────────────────
# Set a numeric PIN to lock the app on first load (e.g. "1234")
# Leave blank to disable PIN lock
VITE_PIN=
